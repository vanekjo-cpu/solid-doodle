# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=device_monitor
DB_USER=monitor_user
DB_PASSWORD=change_me_in_production
DB_SSL=false
DB_LOGGING=false

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0
API_SECRET=your_super_secret_jwt_key_change_in_production
API_LOG_LEVEL=info

# Backend URL (for device connections)
BACKEND_URL=https://monitor.yourcompany.com/api

# Security
CORS_ORIGIN=https://dashboard.yourcompany.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_REQUEST_SIZE=10mb

# Data Retention
DATA_RETENTION_DAYS=90
AUTOMATIC_CLEANUP=true
CLEANUP_CHECK_INTERVAL_HOURS=24

# Encryption
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY=generate_a_256_bit_key_and_keep_it_secret
ENCRYPTION_IV=generate_a_128_bit_initialization_vector

# Alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=security@yourcompany.com
ALERT_EMAIL_TO=security-team@yourcompany.com
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=your_email@yourcompany.com
SMTP_PASS=your_app_password

# Logging
LOG_FORMAT=json
LOG_LEVEL=info
LOG_DIR=/var/log/device-monitor/

# Feature Flags
FEATURE_REAL_TIME_ALERTS=true
FEATURE_DEVICE_GEOLOCATION=false
FEATURE_SCREEN_MONITORING=false
FEATURE_KEYBOARD_LOGGING=false

# Development
NODE_ENV=production
DEBUG=false